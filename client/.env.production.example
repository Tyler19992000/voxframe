# In production the client is served by the same Express server,
# so the API base URL is just the Railway domain (no separate port).
# Set these in Railway's environment variable dashboard — NOT here.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Starter: $6.99/mo or $59/yr, 10 exports/month
VITE_STRIPE_STARTER_MONTHLY_PRICE_ID=price_...
VITE_STRIPE_STARTER_ANNUAL_PRICE_ID=price_...
# Pro: $9.99/mo or $84/yr, unlimited exports
VITE_STRIPE_PRO_MONTHLY_PRICE_ID=price_...
VITE_STRIPE_PRO_ANNUAL_PRICE_ID=price_...

# Leave blank in production — same-origin requests don't need a prefix
VITE_API_URL=
